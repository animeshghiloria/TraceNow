# ──────────────────────────────────────────────────────────
# TraceNow Mobile — Expo environment variables
# Copy to .env and fill in your Firebase Web App config
# These are PUBLIC (baked into the app bundle) — don't put secrets here
# ──────────────────────────────────────────────────────────

# Backend API (change to your server IP when testing on a physical device)
EXPO_PUBLIC_API_BASE_URL=http://localhost/api
EXPO_PUBLIC_WS_URL=http://localhost

# Firebase Web App config
# Get from: Firebase Console → Project Settings → General → Your Apps → Web
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=
