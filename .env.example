# ════════════════════════════════════════════
# TraceNow — Environment Variables
# Copy this file to .env and fill in the values
# ════════════════════════════════════════════

# ── PostgreSQL ──────────────────────────────
POSTGRES_DB=tracenow
POSTGRES_USER=tracenow
POSTGRES_PASSWORD=tracenow_secret

# ── Redis ───────────────────────────────────
REDIS_PASSWORD=redis_secret

# ── JWT ─────────────────────────────────────
JWT_SECRET=change_me_to_a_strong_random_secret
JWT_EXPIRES_IN=7d

# ── Firebase ────────────────────────────────
# Base64-encoded contents of your Firebase service account JSON
# Run: base64 -i service-account.json | tr -d '\n'
FIREBASE_SERVICE_ACCOUNT=<base64_encoded_service_account_json>

# ── AWS / S3 ────────────────────────────────
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_S3_BUCKET=tracenow-images
AWS_REGION=ap-south-1

# ── AI Microservice ─────────────────────────
AI_SERVICE_URL=http://ai-service:8000
CONFIDENCE_THRESHOLD=0.75          # 0-1; sightings above this notify authorities
FAISS_INDEX_PATH=/app/data/faiss.index

# ── Alert Settings ──────────────────────────
ALERT_RADIUS_KM=5                  # default radius for geo-based alerts

# ── Backend ─────────────────────────────────
NODE_ENV=development
PORT=3000
